# ===========================================
# Express TypeScript Boilerplate - Environment Variables
# ===========================================
# Copy this file to .env and adjust values for your environment.
# Production values are marked with [PROD].

# --- Database ---
DATABASE_URL=postgresql://admin:password123@localhost:5432/express-typescript-boilerplate
# [PROD] DATABASE_URL=postgresql://admin:<strong-password>@postgres:5432/express-typescript-boilerplate

POSTGRES_USER=admin
# [PROD] POSTGRES_USER=<change-me>
POSTGRES_PASSWORD=password123
# [PROD] POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=express-typescript-boilerplate

# --- Redis ---
REDIS_URL=redis://localhost:6379
# [PROD] REDIS_URL=redis://:<strong-password>@redis:6379
# [PROD] REDIS_PASSWORD=<change-me>

# These localhost URLs are for running the API on your host with `npm run dev`.
# The production Compose file uses internal service hostnames instead.

# --- JWT ---
JWT_SECRET=change-me-jwt-secret-key-at-least-32-characters
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30

# --- Admin Seed ---
ADMIN_NAME="Super Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123
# [PROD] ADMIN_PASSWORD=<change-me>

# --- Application ---
NODE_ENV=development
# [PROD] NODE_ENV=production
PORT=3000

# --- Logging ---
LOG_LEVEL=debug
# [PROD] LOG_LEVEL=info

# --- Optional Modules ---
CACHE_ENABLED=true
JOBS_ENABLED=true

# --- CORS ---
# ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# --- Bull Board (queue monitoring UI at /admin/queues) ---
# Set both values to enable the dashboard
# BULL_BOARD_USERNAME=queue-admin
# BULL_BOARD_PASSWORD=change-me

# --- GHCR (GitHub Container Registry, prod only) ---
# GITHUB_REPOSITORY_OWNER=locnguyen
